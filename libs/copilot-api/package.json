{
  "name": "copilot-api",
  "description": "GitHub Copilot → Anthropic/OpenAI 协议反代（auth / usage / debug / start）",
  "bin": "index.ts",
  "setup": {
    "desc": "GitHub OAuth 认证（token → ~/.local/share/copilot-api/）",
    "run": "ax.ts copilot-api auth"
  },
  "service": {
    "exec": "bun index.ts start",
    "restart": "always",
    "restartSec": 5
  }
}
